# Pangolin connection
PANGOLIN_URL=https://api.url.of.your.pangolin.instance
ORG_ID=your_org_id
PANGOLIN_TOKEN=your_pangolin_api_token
RESOURCE_IDS=1,2  # comma-separated list of resource IDs. Run the container once to see available IDs in logs.

# Retention and cleanup
RETENTION_MINUTES=43200    # minutes before an IP's rule is removed after last check-in (default 30 days)
CLEANUP_INTERVAL_MINUTES=60  # how often the cleanup loop runs (default 1 hour)

# Rule settings
RULE_PRIORITY=0
RULES_CACHE_TTL_SECONDS=3600  # how long to cache Pangolin rule existence checks (~1 hour)

# State
STATE_FILE=/data/state.json

# ---------------------------------------------------------------------------
# CrowdSec integration (optional — disabled by default)
# ---------------------------------------------------------------------------
CROWDSEC_ENABLED=false
CROWDSEC_ALLOWLIST_NAME=pangolin-ip-rule-manager
CROWDSEC_CACHE_TTL_SECONDS=3600

# --- Mode A: LAPI (recommended) ---
# cscli runs inside this container and authenticates to the CrowdSec LAPI over
# the Docker network. No docker socket required.
#
# One-time setup on your CrowdSec host:
#   docker exec crowdsec cscli machines add pangolin-ip-rule-manager --auto -f -
#   (prefix with sudo if your Docker setup requires it)
# Copy the printed login and password into the vars below.
# The container must be on the same Docker network as your CrowdSec container.
CROWDSEC_LAPI_URL=http://crowdsec:8080   # required for LAPI mode
CROWDSEC_LAPI_LOGIN=pangolin-ip-rule-manager
CROWDSEC_LAPI_PASSWORD=                  # generated by cscli machines add

# --- Mode B: Docker exec (legacy) ---
# Runs cscli inside the CrowdSec container via `docker exec`. Requires the
# Docker socket to be mounted read-only and docker-cli in the image.
# Leave these empty when using Mode A.
CROWDSEC_CMD_PREFIX=                     # set to "docker exec crowdsec" for Mode B
CROWDSEC_CSCLI_BIN=cscli

# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------
SITE_NAME=   # shown in HTML page header/footer; leave empty to omit
UPDATE_ENDPOINT_ENABLED=false
